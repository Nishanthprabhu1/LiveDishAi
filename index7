<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=0"/>
<title>Chef Nishanth — Church Street</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --gold:#C9A84C;
  --gold2:#E8C96A;
  --gold-dim:rgba(201,168,76,0.12);
  --gold-glow:rgba(201,168,76,0.22);
  --void:#08080A;
  --surface:#ffffff;
  --surface2:#fafafa;
  --surface3:#f3f3f3;
  --mist:rgba(255,255,255,0.06);
  --mist2:rgba(255,255,255,0.03);
   --text:#111111;
  --text2:#666666;
  --text3:#999999;
  --red:#FF4D4D;
  --green:#3DBA7A;
  --border:rgba(0,0,0,.08);
  --border2:rgba(0,0,0,.04);
}
body{font-family:'DM Sans',sans-serif;background:#f7f7f7;;color:var(--text);min-height:100vh;max-width:480px;margin:0 auto;position:relative;overflow-x:hidden;}
h1,h2,.display{font-family:'Cormorant Garamond',serif;}

/* ======= AURORA BACKGROUND ======= */
#aurora-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.55;}
.page-layer{position:relative;z-index:1;}

/* ======= HEADER ======= */
.hdr{background:rgba(255,255,255,.92);position:sticky;top:0;z-index:100;backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border-bottom:1px solid var(--border);}
.hdr-inner{display:flex;align-items:center;gap:10px;padding:13px 16px;}
.back-btn{width:34px;height:34px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);flex-shrink:0;transition:all .2s;}
.back-btn:hover{border-color:var(--gold);color:var(--gold);}
.hdr-name{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:600;letter-spacing:0.4px;flex:1;}
.hdr-loc{font-size:10px;color:var(--text3);letter-spacing:0.3px;}
.search-icon{width:34px;height:34px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);transition:all .2s;}
.search-icon:hover{border-color:var(--gold);color:var(--gold);}
.cart-pill{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#0A0800;border:none;border-radius:20px;padding:7px 14px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;display:none;align-items:center;gap:5px;box-shadow:0 0 16px var(--gold-glow);transition:transform .15s;}
.cart-pill:active{transform:scale(0.94);}

/* ======= AURORA BACKGROUND ======= */
.sk-card{
  height:140px;
  border-radius:22px;
  margin-bottom:16px;
  background:
  linear-gradient(
  90deg,
  #f2f2f2 25%,
  #fafafa 50%,
  #f2f2f2 75%);
  background-size:200% 100%;
  animation:shimmer 1.2s infinite;
}

@keyframes shimmer{
  from{background-position:200% 0;}
  to{background-position:-200% 0;}
}
.skeleton-wrap{padding:18px;}
.waiter-fab{
  position:fixed;
  right:20px;
  bottom:95px;
  width:58px;
  height:58px;
  border:none;
  border-radius:50%;
  background:#D4AF37;
  color:#111;
  font-size:24px;
  cursor:pointer;
  z-index:300;
  box-shadow:0 8px 25px rgba(212,175,55,.35);
  transition:.25s;
}
.waiter-fab:hover{transform:translateY(-4px);}

/* ===================================
PREMIUM HERO
=================================== */
.premium-hero{
    position:relative;
    height:340px;
    overflow:hidden;
}
.hero-banner{
    width:100%;
    height:100%;
    object-fit:cover;
}
.hero-overlay{
    position:absolute;
    inset:0;
    background:linear-gradient(rgba(0,0,0,.15),rgba(0,0,0,.75));
}
.hero-content{
    position:absolute;
    left:24px;
    bottom:35px;
    color:white;
}
.hero-badge{
    color:#D4AF37;
    font-size:12px;
    letter-spacing:2px;
    font-weight:600;
}
.hero-content h1{
    margin-top:8px;
    font-size:58px;
    line-height:.85;
    font-family:'Cormorant Garamond',serif;
}
.hero-content p{
    margin-top:14px;
    font-size:13px;
    color:#e0e0e0;
    max-width:240px;
}
.premium-footer{
  margin-top:40px;
  padding:40px 20px 120px;
  text-align:center;
  background:#fff;
  border-top:1px solid rgba(0,0,0,.08);
}
.premium-footer h3{
  font-family:'Cormorant Garamond',serif;
  font-size:30px;
  margin-bottom:8px;
}
.premium-footer p{color:#777;font-size:13px;}

/* ======= SEARCH ======= */
.search-wrap{
    margin:-28px 18px 18px;
    position:relative;
    z-index:10;
    background:white;
    border:none;
    border-radius:999px;
    display:flex;
    align-items:center;
    gap:12px;
    padding:14px 20px;
    height:58px;
    box-shadow:0 2px 12px rgba(0,0,0,.04),0 10px 35px rgba(0,0,0,.06);
}

/* ======= CAT CHIPS ======= */
.cat-row{padding:0 18px 14px;overflow-x:auto;scrollbar-width:none;display:flex;gap:7px;}
.cat-row::-webkit-scrollbar{display:none;}
.cat-chip{border:1px solid var(--border);border-radius:20px;padding:7px 14px;font-size:11.5px;font-weight:500;background:var(--surface2);color:var(--text2);cursor:pointer;white-space:nowrap;transition:all .18s;}
.cat-chip.active{background:rgba(201,168,76,0.1);border-color:var(--gold);color:var(--gold);font-weight:600;}

/* ==========================
CHEF PICKS
========================== */
.chef-picks{margin:12px 0 24px;}
.chef-title{
  font-family:'Cormorant Garamond',serif;
  font-size:32px;
  font-weight:700;
  padding:0 18px;
  color:#111;
  margin-bottom:14px;
}
.chef-scroll{
  display:flex;
  gap:18px;
  overflow-x:auto;
  padding:0 18px;
}
.chef-scroll::-webkit-scrollbar{display:none;}
.chef-card{
  min-width:240px;
  background:#fff;
  border-radius:22px;
  overflow:hidden;
  box-shadow:0 2px 12px rgba(0,0,0,.04),0 10px 35px rgba(0,0,0,.06);
  transition:transform .25s ease;
}
.chef-card:hover{transform:translateY(-4px);}
.chef-card img{
  width:100%;
  height:160px;
  object-fit:cover;
}
.chef-info{padding:14px;}
.chef-name{font-size:15px;font-weight:700;color:#111;}
.chef-price{font-size:14px;color:#666;margin-top:4px;}

/* ======= MENU SECTIONS ======= */
.menu-sec{
  background:transparent;
  margin:20px 14px;
  border:none;
  border-top:1px solid var(--border2);
  border-bottom:1px solid var(--border2);
}
.sec-hdr{
  padding:0 4px 14px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.sec-title{font-size:30px;font-family:'Cormorant Garamond',serif;font-weight:700;color:#111;}
.sec-count{font-size:10px;color:var(--text3);margin-top:1px;}
.sec-arrow{font-size:12px;color:var(--text3);transition:transform .2s;}
.sec-arrow.open{transform:rotate(180deg);color:var(--gold);}
.sec-body{padding:0 18px 6px;}
.menu-item{
  background:#fff;
  border-radius:22px;
  padding:18px;
  margin-bottom:16px;
  display:flex;
  gap:14px;
  align-items:flex-start;
  transition:transform .25s ease,box-shadow .25s ease;
  box-shadow:0 2px 12px rgba(0,0,0,.04),0 10px 35px rgba(0,0,0,.06);
  border:none;
}
.menu-item:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 40px rgba(0,0,0,.10);
}
.item-img img{transition:transform .4s ease;}
.menu-item:hover .item-img img{transform:scale(1.08);}
.item-left{flex:1;min-width:0;}
.type-ico{margin-bottom:5px;}
.veg-ico{width:13px;height:13px;border:1.5px solid var(--green);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;}
.veg-ico::after{content:'';width:4px;height:4px;border-radius:50%;background:var(--green);}
.nveg-ico{width:13px;height:13px;border:1.5px solid var(--red);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;}
.nveg-ico::after{content:'';width:4px;height:4px;border-radius:50%;background:var(--red);}
.item-name{font-size:17px;font-weight:700;color:#111;margin-bottom:8px;}
.bs-tag{display:inline-flex;align-items:center;gap:2px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.2);color:var(--gold);font-size:9px;font-weight:700;padding:1px 6px;border-radius:4px;margin-left:5px;vertical-align:middle;letter-spacing:0.3px;}
.item-desc{font-size:13px;color:#666;line-height:1.5;margin-bottom:12px;}
.price-row{display:flex;align-items:center;gap:9px;}
.item-price{font-size:20px;font-weight:700;color:#111;}
.liked-lbl{font-size:10.5px;color:var(--green);font-weight:500;}
.cust-note{font-size:9.5px;color:var(--gold);font-weight:500;margin-top:5px;letter-spacing:0.3px;}
.item-right{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:7px;}
.item-img{
  width:120px;
  height:120px;
  border-radius:18px;
  overflow:hidden;
  background:#f7f7f7;
  flex-shrink:0;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:54px;
  box-shadow:0 6px 18px rgba(0,0,0,.08);
}
.item-img img{width:100%;height:100%;object-fit:cover;display:block;}

/* ======= BUTTONS ======= */
.add-btn{
  background:#111;
  color:#fff;
  border:none;
  border-radius:999px;
  padding:10px 24px;
  font-size:12px;
  font-weight:700;
  cursor:pointer;
}
.add-btn:hover{background:var(--gold);color:#0A0800;border-color:transparent;}
.qty-ctrl{display:flex;align-items:center;background:var(--gold);border-radius:7px;overflow:hidden;box-shadow:0 3px 10px var(--gold-glow);height:27px;}
.qty-ctrl button{background:transparent;border:none;color:#0A0800;font-size:14px;font-weight:700;width:25px;height:100%;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.qty-ctrl span{color:#0A0800;font-size:12px;font-weight:700;min-width:14px;text-align:center;}
.ar-btn{
  background:#D4AF37;
  color:#111;
  border:none;
  border-radius:999px;
  padding:8px 16px;
  font-size:11px;
  font-weight:700;
  cursor:pointer;
}
.ar-btn:hover{background:var(--gold);color:#0A0800;}
.ar-btn svg{width:10px;height:10px;}

/* ======= CART FOOTER ======= */
.cart-foot{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;padding:14px;z-index:99;display:none;}
.cart-foot.show{display:block;}
.cart-foot::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,rgba(8,8,10,0.97) 35%);pointer-events:none;}
.cart-foot-inner{position:relative;}
.cart-btn{background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 100%);color:#0A0800;border:none;border-radius:13px;padding:13px 18px;width:100%;font-family:'DM Sans',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:space-between;box-shadow:0 8px 24px rgba(201,168,76,0.3);transition:all .18s;}
.cart-btn:active{transform:scale(0.98);}
.cart-lft{display:flex;flex-direction:column;align-items:flex-start;line-height:1.2;}
.cart-cnt{font-size:9.5px;font-weight:600;opacity:0.7;text-transform:uppercase;letter-spacing:0.6px;}
.cart-tot{font-size:15px;font-weight:700;}
.cart-rgt{font-size:12.5px;font-weight:600;display:flex;align-items:center;gap:3px;}

/* ======= OVERLAY & SHEETS ======= */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;opacity:0;pointer-events:none;transition:opacity .22s;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);}
.overlay.show{opacity:1;pointer-events:all;}
.btm-sheet{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:480px;background:var(--surface);border-radius:18px 18px 0 0;z-index:201;transition:transform .28s cubic-bezier(.32,.72,0,1);max-height:85vh;overflow-y:auto;border-top:1px solid var(--border);}
.btm-sheet.show{transform:translateX(-50%) translateY(0);}
.sheet-handle{width:36px;height:3px;background:rgba(255,255,255,0.12);border-radius:2px;margin:11px auto;}
.sheet-img{height:155px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:62px;border-bottom:1px solid var(--border);overflow:hidden;}
.sheet-img img{width:100%;height:100%;object-fit:cover;display:block;}
.sheet-body{padding:18px 18px 100px;}
.sheet-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;margin-bottom:3px;}
.sheet-price{font-size:17px;font-weight:600;margin-bottom:8px;color:var(--gold);}
.sheet-liked{font-size:10.5px;color:var(--green);font-weight:500;margin-bottom:10px;}
.sheet-desc{font-size:12px;color:var(--text2);line-height:1.6;margin-bottom:15px;}
.cust-sec{border-top:1px solid var(--border2);padding-top:14px;margin-top:14px;}
.cust-ttl{font-size:12.5px;font-weight:600;margin-bottom:2px;letter-spacing:0.1px;}
.cust-sub{font-size:10.5px;color:var(--text3);margin-bottom:12px;}
.cust-opt{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.03);}
.cust-opt:last-child{border-bottom:none;}
.opt-name{font-size:12.5px;color:var(--text);}
.opt-price{font-size:11.5px;color:var(--text3);}
.radio-c{width:17px;height:17px;border-radius:50%;border:2px solid var(--text3);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;}
.radio-c.sel{border-color:var(--gold);background:var(--gold);}
.radio-c.sel::after{content:'';width:5px;height:5px;border-radius:50%;background:#f7f7f7;}
.check-c{width:17px;height:17px;border-radius:4px;border:2px solid var(--text3);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;font-size:10px;color:transparent;}
.check-c.sel{border-color:var(--gold);background:var(--gold);color:var(--void);font-weight:700;}
.sheet-foot{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--surface);padding:12px 18px;border-top:1px solid var(--border);z-index:202;}
.sheet-qty-row{display:flex;align-items:center;gap:12px;}
.sq-ctrl{display:flex;align-items:center;background:var(--surface2);border-radius:9px;border:1px solid var(--border);overflow:hidden;}
.sq-ctrl button{background:transparent;border:none;color:var(--text);font-size:17px;width:36px;height:40px;cursor:pointer;}
.sq-ctrl span{color:var(--text);font-size:13px;font-weight:600;min-width:18px;text-align:center;}
.sheet-add-btn{flex:1;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#0A0800;border:none;border-radius:9px;padding:13px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 14px rgba(201,168,76,0.25);}

/* ======= MODALS ======= */
.modal-wrap{position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:500;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(8px);}
.modal-wrap.show{display:flex;}
.modal-box{background:var(--surface);border-radius:18px 18px 0 0;padding:22px 18px;width:100%;max-width:480px;border-top:1px solid var(--border);}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;margin-bottom:4px;text-align:center;}
.modal-sub{font-size:11.5px;color:var(--text2);margin-bottom:20px;text-align:center;line-height:1.5;}
.modal-input{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:16px;text-align:center;font-weight:600;outline:none;transition:border .2s;}
.modal-input:focus{border-color:rgba(201,168,76,0.5);}
.modal-confirm{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#0A0800;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;margin-top:14px;display:flex;align-items:center;justify-content:center;gap:7px;box-shadow:0 5px 18px rgba(201,168,76,0.22);}
.modal-cancel{text-align:center;margin-top:12px;font-size:11.5px;color:var(--text3);cursor:pointer;transition:color .2s;}
.modal-cancel:hover{color:var(--text);}
.qr-corner{position:absolute;top:-5px;right:-5px;background:var(--gold);color:#0A0800;font-size:7.5px;font-weight:700;border-radius:5px;padding:2px 5px;line-height:1.4;text-transform:uppercase;letter-spacing:0.3px;}

/* ======= SPLIT BILL ======= */
.split-btns{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;}
.split-n{border:1px solid var(--border);border-radius:9px;padding:9px 16px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;background:var(--surface2);color:var(--text2);transition:all .18s;}
.split-n.sel{border-color:var(--gold);background:rgba(201,168,76,0.08);color:var(--gold);}
.split-result{background:var(--surface2);border-radius:10px;border:1px solid var(--border);padding:14px;text-align:center;}
.split-amt{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;color:var(--gold);margin-top:2px;}

/* ======= AI MODAL ======= */
.ai-box{background:linear-gradient(135deg,rgba(201,168,76,0.06) 0%,var(--surface2) 100%);border:1px solid rgba(201,168,76,0.18);color:var(--text);border-radius:12px;padding:14px;margin-bottom:14px;}
.ai-ttl{font-size:12.5px;font-weight:600;margin-bottom:3px;color:var(--gold);}
.ai-txt{font-size:11px;color:var(--text2);line-height:1.5;}
.ai-items{display:flex;flex-direction:column;gap:9px;}
.ai-item{background:var(--surface2);border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;border:1px solid var(--border2);}
.ai-item-emoji{font-size:20px;}
.ai-item-nm{font-size:12.5px;font-weight:600;color:var(--text);}
.ai-item-why{font-size:10.5px;color:var(--text3);margin-top:1px;line-height:1.4;}
.ai-item-price{font-size:12.5px;font-weight:600;color:var(--gold);}

/* ======= UPSELL ======= */
.upsell-card{background:var(--surface2);border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;margin-bottom:8px;cursor:pointer;border:1px solid var(--border2);transition:border-color .15s;}
.upsell-card:hover{border-color:rgba(201,168,76,0.3);}

/* ======= GROUP ORDER ======= */
.group-link{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 12px;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.group-link-txt{font-size:11.5px;color:var(--text);font-family:monospace;}
.copy-btn{background:var(--gold);color:#0A0800;border:none;border-radius:7px;padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;}
.g-person{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border2);}
.g-avatar{width:34px;height:34px;border-radius:50%;background:var(--surface3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--gold);}
.g-nm{font-size:12.5px;font-weight:600;}
.g-its{font-size:10.5px;color:var(--text3);margin-top:1px;}
.g-ok{font-size:10.5px;color:var(--green);font-weight:500;}

/* ======= SERVICE OPTS ======= */
.svc-opt{border:1px solid var(--border);border-radius:12px;padding:12px;display:flex;align-items:center;gap:12px;cursor:pointer;margin-bottom:8px;background:var(--surface2);transition:all .15s;}
.svc-opt.sel{border-color:rgba(201,168,76,0.4);background:rgba(201,168,76,0.06);}
.svc-icon{font-size:22px;}
.svc-nm{font-size:12.5px;font-weight:600;}
.svc-desc{font-size:10.5px;color:var(--text3);margin-top:1px;}

/* ======= REORDER ======= */
.reorder-card{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:10px;}
.reorder-date{font-size:10.5px;color:var(--text3);margin-bottom:5px;}
.reorder-items{font-size:12.5px;font-weight:500;color:var(--text);line-height:1.4;margin-bottom:7px;}
.reorder-tot{font-size:11.5px;color:var(--gold);margin-bottom:10px;font-weight:500;}
