  } catch(e) {
    c.innerHTML = `<div style="text-align:center;padding:60px 20px;">
      <div style="font-size:28px;margin-bottom:10px;">⚠️</div>
      <div style="font-size:13px;font-weight:600;color:var(--red);margin-bottom:6px;">Could not load menu</div>
      <div style="font-size:11px;color:var(--text3);margin-bottom:14px;">Check connection or endpoint.</div>
      <button onclick="loadMenu()" style="background:var(--gold);color:#0A0800;border:none;border-radius:8px;padding:9px 18px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;cursor:pointer;">Retry</button>
    </div>`;
  }
}

function renderChefPicks(){
  const wrap = document.getElementById('chefPicks');
  if(!wrap) return;
  const picks = menuData.filter(i => i.bestseller).slice(0,5);
  wrap.innerHTML = picks.map(item => `
    <div class="chef-card" onclick="openSheet('${ek(item.name)}')">
      <img src="${getItemImage(item)}" alt="${item.name}" loading="lazy"
           onerror="this.style.display='none'">
      <div class="chef-info">
        <div class="chef-name">${item.name}</div>
        <div class="chef-price">₹${item.price}</div>
      </div>
    </div>
  `).join('');
}

function getFiltered(){
  return menuData.filter(i => {
    const cm = curCat === 'all' || i.cat === curCat;
    const sm = !search || i.name.toLowerCase().includes(search) || i.desc.toLowerCase().includes(search);
    const vm = !vegOnly || i.type === 'veg';
    return cm && sm && vm;
  });
}

function renderMenu(){
  const filtered = getFiltered();
  const c = document.getElementById('menuContainer');
  if(!filtered.length){
    c.innerHTML = '<div style="text-align:center;padding:60px 20px;color:var(--text3);font-size:12px;">No matching dishes found 🔍</div>';
    return;
  }
  const cats = ['starters','mains','biryani','breads','desserts','drinks'];
  const groups = {};
  filtered.forEach(i => { if(!groups[i.cat]) groups[i.cat] = []; groups[i.cat].push(i); });
  let html = '';
  cats.filter(c => groups[c]).forEach(cat => {
    const items = groups[cat];
    html += `<div class="menu-sec">
      <div class="sec-hdr" onclick="toggleSec('sec-${cat}',this)">
        <div><div class="sec-title">${SECTION_LABELS[cat]||cat}</div><div class="sec-count">${items.length} items</div></div>
        <div class="sec-arrow open">▾</div>
      </div>
      <div class="sec-body" id="sec-${cat}">`;
    items.forEach(item => {
      const qty = cart[item.name]?.qty || 0, k = ek(item.name);
      const addArea = qty === 0
        ? `<button class="add-btn" onclick="event.stopPropagation();openSheet('${k}')">ADD</button>`
        : `<div class="qty-ctrl"><button onclick="event.stopPropagation();quickRemove('${k}')">−</button><span>${qty}</span><button onclick="event.stopPropagation();openSheet('${k}')">+</button></div>`;
      const typeIco = item.type === 'veg' ? '<div class="veg-ico"></div>' : '<div class="nveg-ico"></div>';
      html += `<div class="menu-item" onclick="openSheet('${k}')">
        <div class="item-left">
          <div class="type-ico">${typeIco}</div>
          <div class="item-name">${item.name}${item.bestseller?'<span class="bs-tag">⭐ Bestseller</span>':''}</div>
          <div class="item-desc">${item.desc}</div>
          <div class="price-row">
            <div class="item-price">₹${item.price}</div>
            <div class="liked-lbl">👍 ${item.liked}% liked</div>
          </div>
          ${(item.groups||[]).length?'<div class="cust-note">✎ Customisable</div>':''}
        </div>
        <div class="item-right">
          <div class="item-img">
            <img src="${getItemImage(item)}" alt="${item.name}" loading="lazy"
                 onerror="this.style.display='none'">
          </div>
          <div style="display:flex;flex-direction:column;gap:5px;align-items:center;margin-top:6px;">
            ${addArea}
            <button class="ar-btn" onclick="event.stopPropagation();openArModal('${k}')">${SVG_CUBE} AR</button>
          </div>
        </div>
      </div>`;
    });
    html += `</div></div>`;
  });
  c.innerHTML = html;
}

function toggleSec(id, hdr){
  const b = document.getElementById(id);
  const a = hdr.querySelector('.sec-arrow');
  if(b.style.display === 'none'){ b.style.display = ''; a.classList.add('open'); }
  else { b.style.display = 'none'; a.classList.remove('open'); }
}

/* ===== SHEET ===== */
function openSheet(k){
  const item = menuData.find(i => ek(i.name) === k);
  if(!item) return;
  sItem = item; sQty = 1; sRadio = {}; sAddon = {};
  (item.groups||[]).forEach((g,gi) => { if(g.type==='radio') sRadio[gi] = 0; });

  /* ---- IMAGE: use local PNG if available ---- */
  const imgSrc = getItemImage(item);
  document.getElementById('sheetImg').innerHTML = imgSrc
    ? `<img src="${imgSrc}" alt="${item.name}" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentElement.innerHTML='${item.emoji||'🍽️'}';">`
    : item.emoji || '🍽️';

  let h = `<div class="type-ico" style="margin-bottom:5px;">${item.type==='veg'?'<div class="veg-ico"></div>':'<div class="nveg-ico"></div>'}</div>`;
  h += `<div class="sheet-title">${item.name}${item.bestseller?'<span class="bs-tag">⭐ Bestseller</span>':''}</div>`;
  h += `<div class="sheet-price">₹${item.price}</div>`;
  h += `<div class="sheet-liked">👍 ${item.liked}% of diners recommended this</div>`;
  h += `<div class="sheet-desc">${item.desc}</div>`;
  (item.groups||[]).forEach((g,gi) => {
    h += `<div class="cust-sec"><div class="cust-ttl">${g.title}</div><div class="cust-sub">${g.sub}</div>`;
    (g.opts||[]).forEach((opt,oi) => {
      h += `<div class="cust-opt"><div style="display:flex;align-items:center;gap:9px;"><div class="radio-c${sRadio[gi]===oi?' sel':''}" id="rc-${gi}-${oi}" onclick="selRadio(${gi},${oi})"></div><div class="opt-name">${opt.n}</div></div><div class="opt-price">${opt.e?'+₹'+opt.e:''}</div></div>`;
    });
    h += `</div>`;
  });
  if(item.addons && item.addons.length){
    h += `<div class="cust-sec"><div class="cust-ttl">Add-ons</div><div class="cust-sub">Optional enhancements</div>`;
    item.addons.forEach((ao,ai) => {
      h += `<div class="cust-opt"><div style="display:flex;align-items:center;gap:9px;"><div class="check-c${sAddon[ai]?' sel':''}" id="cc-${ai}" onclick="togAddon(${ai})">${sAddon[ai]?'✓':''}</div><div class="opt-name">${ao.n}</div></div><div class="opt-price">+₹${ao.e}</div></div>`;
    });
    h += `</div>`;
  }
  document.getElementById('sheetBody').innerHTML = h;
  document.getElementById('sqNum').textContent = sQty;
  updateSheetBtn();
  document.getElementById('overlay').classList.add('show');
  document.getElementById('btmSheet').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeSheet(){
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('btmSheet').classList.remove('show');
  document.body.style.overflow = '';
  sItem = null;
}
function selRadio(gi,oi){
  sRadio[gi] = oi;
  (sItem.groups[gi].opts||[]).forEach((_,idx) => {
    const el = document.getElementById(`rc-${gi}-${idx}`);
    if(el) el.className = 'radio-c' + (idx===oi?' sel':'');
  });
  updateSheetBtn();
}
function togAddon(ai){
  sAddon[ai] = !sAddon[ai];
  const el = document.getElementById(`cc-${ai}`);
  if(el){ el.className = 'check-c' + (sAddon[ai]?' sel':''); el.textContent = sAddon[ai]?'✓':''; }
  updateSheetBtn();
}
function sqChange(d){ sQty = Math.max(1,sQty+d); document.getElementById('sqNum').textContent = sQty; updateSheetBtn(); }
function calcPrice(){
  if(!sItem) return 0;
  let p = sItem.price;
  (sItem.groups||[]).forEach((g,gi) => { if(g.type==='radio'&&sRadio[gi]!=null) p += g.opts[sRadio[gi]].e; });
  if(sItem.addons) sItem.addons.forEach((ao,ai) => { if(sAddon[ai]) p += ao.e; });
  return p;
}
function updateSheetBtn(){
  const t = calcPrice() * sQty;
  document.getElementById('sheetAddBtn').textContent = `Add to cart — ₹${t.toLocaleString('en-IN')}`;
}
function addFromSheet(){
  if(!sItem) return;
  const k = sItem.name, u = calcPrice();
  if(!cart[k]) cart[k] = {item:sItem, qty:0, price:0, entries:[]};
  cart[k].qty += sQty; cart[k].price += u*sQty; cart[k].entries.push({qty:sQty, u});
  updateCartUI(); renderMenu();
  const upsells = sItem.upsells || [];
  closeSheet();
  if(upsells.length){ setTimeout(() => openUpsell(upsells), 300); }
  else showToast(`${sItem.name} added! 🛒`);
}
function quickRemove(k){
  const item = menuData.find(i => ek(i.name) === k);
  if(!item || !cart[item.name]) return;
  const e = cart[item.name].entries.pop();
  if(e){ cart[item.name].qty -= e.qty; cart[item.name].price -= e.u*e.qty; }
  if(cart[item.name].qty <= 0) delete cart[item.name];
  updateCartUI(); renderMenu();
}
function updateCartUI(){
  const keys = Object.keys(cart);
  const tq = keys.reduce((s,k) => s+cart[k].qty, 0);
  const tp = keys.reduce((s,k) => s+cart[k].price, 0);
  document.getElementById('cartCntLbl').textContent = `${tq} item${tq!==1?'s':''}`;
  document.getElementById('cartTotVal').textContent = tp.toLocaleString('en-IN');
  document.getElementById('hdrCartCnt').textContent = tq;
  const f = document.getElementById('cartFoot');
  const hb = document.getElementById('hdrCartBtn');
  if(tq > 0){ f.classList.add('show'); hb.style.display = 'flex'; }
  else { f.classList.remove('show'); hb.style.display = 'none'; }
  updateSplitAmt();
}

/* ===== MODALS ===== */
function openModal(id){ document.getElementById(id).classList.add('show'); }
function closeModal(id){ document.getElementById(id).classList.remove('show'); }
function closeAllSheets(){ closeSheet(); }
function openTableModal(){
  if(!Object.keys(cart).length){ showToast('Cart is empty!'); return; }
  document.getElementById('tableInput').value = '';
  openModal('tableModal');
}
window.openSplitBill = () => openModal('splitModal');
window.openCallWaiter = () => openModal('waiterModal');
window.openGroupOrder = () => openModal('groupModal');
window.openReorder = () => openModal('reorderModal');

function setSplit(n,btn){
  splitN = n;
  document.querySelectorAll('.split-n').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  updateSplitAmt();
}
function updateSplitAmt(){
  const tp = Object.keys(cart).reduce((s,k) => s+cart[k].price, 0);
  document.getElementById('splitAmt').textContent = tp > 0 ? '₹' + Math.round(tp/splitN) : '₹0';
}
function sendWaiter(){ closeModal('waiterModal'); showToast('Waiter notified! 🛎️ They will arrive shortly.'); }
function selectSvc(el){ document.querySelectorAll('.svc-opt').forEach(e => e.classList.remove('sel')); el.classList.add('sel'); }

function openUpsell(names){
  const items = names.map(n => menuData.find(i => i.name===n)).filter(Boolean);
  if(!items.length){ showToast('Added to cart! 🛒'); return; }
  let h = '';
  items.forEach(item => {
    const k = ek(item.name);
    h += `<div class="upsell-card" onclick="addUpsellItem('${k}')">
      <div style="font-size:22px;">${item.emoji||'🍽️'}</div>
      <div style="flex:1;"><div style="font-size:12.5px;font-weight:600;">${item.name}</div><div style="font-size:11px;color:var(--text3);">₹${item.price}</div></div>
      <div style="font-size:11px;color:var(--gold);font-weight:600;">+ ADD</div>
    </div>`;
  });
  document.getElementById('upsellList').innerHTML = h;
  openModal('upsellModal');
}
function addUpsellItem(k){
  const item = menuData.find(i => ek(i.name)===k);
  if(!item) return;
  if(!cart[item.name]) cart[item.name] = {item, qty:0, price:0, entries:[]};
  cart[item.name].qty += 1; cart[item.name].price += item.price; cart[item.name].entries.push({qty:1, u:item.price});
  updateCartUI(); renderMenu();
  closeModal('upsellModal'); showToast(`${item.name} added! 🛒`);
}

function openAIRecommend(){
  const recs = [
    {name:'Butter Chicken Masala', reason:'Most celebrated selection this week'},
    {name:'Garlic Kulcha', reason:'Recommended pairing accompaniment'},
    {name:'Mango Lassi', reason:'Top-rated traditional beverage'},
    {name:'Gulab Jamun with Ice Cream', reason:'Signature dessert pairing'}
  ];
  const items = recs.map(r => ({...menuData.find(i => i.name===r.name), ...r})).filter(i => i && i.price);
  let total = 0, h = '';
  items.forEach(item => {
    total += item.price;
    h += `<div class="ai-item"><div class="ai-item-emoji">${item.emoji||'🍽️'}</div><div style="flex:1;"><div class="ai-item-nm">${item.name}</div><div class="ai-item-why">${item.reason}</div></div><div class="ai-item-price">₹${item.price}</div></div>`;
  });
  document.getElementById('aiItemList').innerHTML = h;
  document.getElementById('aiTotal').textContent = total;
  openModal('aiModal');
}
function addAIRecommend(){
  ['Butter Chicken Masala','Garlic Kulcha','Mango Lassi','Gulab Jamun with Ice Cream'].forEach(name => {
    const item = menuData.find(i => i.name===name);
    if(!item) return;
    if(!cart[name]) cart[name] = {item, qty:0, price:0, entries:[]};
    cart[name].qty += 1; cart[name].price += item.price; cart[name].entries.push({qty:1, u:item.price});
  });
  closeModal('aiModal'); updateCartUI(); renderMenu(); showToast('AI curated combo added! 🤖🛒');
}

function reorderLast(){
  [{name:'Butter Chicken Masala',p:380},{name:'Garlic Kulcha',p:80},{name:'Mango Lassi',p:120}].forEach(({name,p}) => {
    const item = menuData.find(i => ek(i.name)===name); if(!item) return;
    if(!cart[name]) cart[name] = {item, qty:0, price:0, entries:[]};
    cart[name].qty += 1; cart[name].price += p; cart[name].entries.push({qty:1, u:p});
  });
  closeModal('reorderModal'); updateCartUI(); renderMenu(); showToast('Previous order replicated! 🔁');
}

async function confirmOrder(){
  const t = document.getElementById('tableInput').value.trim();
  if(!t){ document.getElementById('tableInput').style.borderColor='var(--red)'; setTimeout(()=>document.getElementById('tableInput').style.borderColor='',1500); return; }
  closeModal('tableModal');
  document.getElementById('sendingOvl').classList.add('show');
  const now = new Date();
  const keys = Object.keys(cart);
  const total = keys.reduce((s,k) => s+cart[k].price, 0);
  const payload = {
    date: now.toLocaleDateString('en-GB'),
    time: now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true}),
    table: t,
    items: keys.map(k => { const e = cart[k].entries[0]||{qty:cart[k].qty,u:cart[k].price/cart[k].qty}; return{name:k,qty:cart[k].qty,unitPrice:e.u,subtotal:cart[k].price}; }),
    orderTotal: total
  };
  try { await fetch(WEBHOOK_URL,{method:'POST',headers:{'Content-Type':'text/plain;charset=utf-8'},body:JSON.stringify(payload)}); } catch(e){}
  Object.keys(cart).forEach(k => delete cart[k]);
  updateCartUI(); renderMenu();
  document.getElementById('sendingOvl').classList.remove('show');
  showToast('Order dispatched to kitchen! 🧑‍🍳🎉');
}

/* ===== FILTERS ===== */
function filterCat(c,el){ curCat=c; document.querySelectorAll('.cat-chip').forEach(e=>e.classList.remove('active')); el.classList.add('active'); renderMenu(); }
function filterMenu(){ search=document.getElementById('searchInput').value.toLowerCase().trim(); renderMenu(); }
function toggleVeg(){ vegOnly=!vegOnly; renderMenu(); }
function focusSearch(){ document.getElementById('searchInput').focus(); }

/* ===== TOAST ===== */
let toastT;
function showToast(msg){
  const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show');
  clearTimeout(toastT); toastT=setTimeout(()=>t.classList.remove('show'),2500);
}

/* ===== AR ===== */
const elMV = document.getElementById('main-mv');
const elMvWrap = document.getElementById('ar-mv-wrapper');
const elMvLoader = document.getElementById('mvLoader');
const elArLaunchWrap = document.getElementById('arLaunchWrap');
const elArLaunch = document.getElementById('arLaunchBtn');
const elArNotSup = document.getElementById('arNotSup');
let mvModulePromise = null, mvModuleReady = false, currentArDish = null, _arToken = 0;

function ensureMV(){ if(!mvModulePromise) mvModulePromise = import('https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js').then(()=>{mvModuleReady=true;}); return mvModulePromise; }

function openArModal(k){
  const d = menuData.find(i => ek(i.name)===k);
  if(!d) return;
  if(!d.folder || !d.file){ showToast('🥽 AR model coming soon!'); return; }
  currentArDish = d;
  const token = ++_arToken;
  document.getElementById('arModalName').textContent = d.name;
  document.getElementById('arModalDesc').textContent = d.desc;
  elMvWrap.classList.remove('mv-vis');
  elArLaunchWrap.style.display = 'none';
  elArNotSup.style.display = 'none';
  elArLaunch.disabled = true;
  elArLaunch.textContent = '⏳ Downloading model…';
  elMvLoader.classList.remove('hidden');
  document.getElementById('arModal').classList.add('open');
  document.body.style.overflow = 'hidden';
  const glbPath = `${ASSETS_BASE}/${d.folder}/${d.file}.glb`;
  ensureMV().then(() => {
    if(_arToken !== token) return;
    const s = (d.scale??1).toFixed(6);
    elMV.setAttribute('scale',`${s} ${s} ${s}`);
    elMV.setAttribute('camera-orbit', d.orbit??'0deg 75deg 105%');
    if(isIOS && d.file) elMV.setAttribute('ios-src',`${ASSETS_BASE}/${d.folder}/${d.file}.usdz`);
    if(elMV.getAttribute('src') === glbPath){ _onGlbDone(d,token); }
    else { elMV.removeAttribute('src'); requestAnimationFrame(()=>{ requestAnimationFrame(()=>{ if(_arToken!==token) return; elMV.setAttribute('src',glbPath); }); }); }
  });
}
function _onGlbDone(d,token){
  if(_arToken !== token) return;
  const s = (d.scale??1).toFixed(6);
  elMV.setAttribute('scale',`${s} ${s} ${s}`);
  elMV.dismissPoster();
  elMvLoader.classList.add('hidden');
  elMvWrap.classList.add('mv-vis');
  const canAR = elMV.canActivateAR;
  elArLaunchWrap.style.display = canAR ? 'flex' : 'none';
  elArNotSup.style.display = canAR ? 'none' : 'block';
  elArLaunch.disabled = false;
  elArLaunch.textContent = '✦ View On Table';
}
elMV.addEventListener('load', () => { if(currentArDish) _onGlbDone(currentArDish, _arToken); });
document.getElementById('arLaunchBtn').addEventListener('click', () => { if(elMV.canActivateAR){ try{ elMV.activateAR(); }catch(e){} } });
function closeArModal(){
  document.getElementById('arModal').classList.remove('open');
  document.body.style.overflow = '';
  currentArDish = null; _arToken++;
  if(mvModuleReady){ if(typeof elMV.pause==='function') elMV.pause(); elMV.removeAttribute('src'); elMV.setAttribute('scale','1 1 1'); }
}

loadMenu();

document.addEventListener('contextmenu', e => e.preventDefault());
document.onkeydown = e => {
  if(e.keyCode===123) return false;
  if(e.ctrlKey && e.shiftKey && [73,74,67,75].includes(e.keyCode)) return false;
  if(e.ctrlKey && e.keyCode===85) return false;
};
