/* ===== AURORA BACKGROUND ANIMATION ===== */
(function(){
  const canvas = document.getElementById('aurora-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [], streams = [], t = 0;

  function resize(){
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  for(let i = 0; i < 55; i++){
    particles.push({
      x: Math.random() * 1000,
      y: Math.random() * 1000,
      vx: (Math.random() - 0.5) * 0.18,
      vy: (Math.random() - 0.5) * 0.12 - 0.05,
      r: Math.random() * 1.4 + 0.3,
      a: Math.random() * Math.PI * 2,
      life: Math.random()
    });
  }

  for(let i = 0; i < 4; i++){
    streams.push({
      phase: i * Math.PI / 2,
      speed: 0.0005 + Math.random() * 0.0004,
      amp: 80 + Math.random() * 120,
      yBase: 0.15 + i * 0.18,
      hue: 38 + i * 8,
      width: 120 + i * 40
    });
  }

  function draw(){
    ctx.clearRect(0, 0, W, H);
    t += 0.012;
    streams.forEach(s => {
      const y0 = H * s.yBase;
      const grad = ctx.createLinearGradient(0, y0 - s.width, 0, y0 + s.width);
      grad.addColorStop(0, 'transparent');
      grad.addColorStop(0.4, `hsla(${s.hue}, 65%, 42%, 0.045)`);
      grad.addColorStop(0.5, `hsla(${s.hue}, 70%, 50%, 0.07)`);
      grad.addColorStop(0.6, `hsla(${s.hue}, 65%, 42%, 0.045)`);
      grad.addColorStop(1, 'transparent');
      ctx.beginPath();
      ctx.moveTo(0, y0);
      for(let x = 0; x <= W; x += 4){
        const wave = Math.sin(x * 0.003 + t * s.speed * 1000 + s.phase) * s.amp
                   + Math.sin(x * 0.007 + t * s.speed * 600 + s.phase * 1.3) * s.amp * 0.4;
        ctx.lineTo(x, y0 + wave);
      }
      ctx.lineTo(W, H); ctx.lineTo(0, H);
      ctx.closePath();
      ctx.fillStyle = grad;
      ctx.fill();
    });

    particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.life += 0.003;
      if(p.y < -10 || p.x < -10 || p.x > W + 10){
        p.x = Math.random() * W;
        p.y = H + 5;
        p.life = 0;
      }
      const alpha = Math.sin(p.life * Math.PI) * 0.45;
      if(alpha <= 0) return;
      ctx.beginPath();
      ctx.arc(p.x % W, p.y % H, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(201,168,76,${alpha})`;
      ctx.fill();
    });

    for(let i = 0; i < particles.length; i++){
      for(let j = i + 1; j < particles.length; j++){
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if(dist < 90){
          const alpha = (1 - dist/90) * 0.08;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = `rgba(201,168,76,${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

